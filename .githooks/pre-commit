#!/bin/sh
set -e
cd "$(git rev-parse --show-toplevel)"

if git diff --cached --name-only | grep -qE '(^|/)\.env$'; then
	echo "error: .env must not be committed" >&2
	exit 1
fi

files=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.py$' || true)
[ -z "$files" ] && exit 0

ruff=".venv/bin/ruff"
if [ ! -x "$ruff" ]; then
	echo "error: $ruff missing - run 'uv sync'" >&2
	exit 1
fi

echo "$files" | xargs "$ruff" check --fix
echo "$files" | xargs "$ruff" format
echo "$files" | xargs git add